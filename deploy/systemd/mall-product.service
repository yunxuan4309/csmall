[Unit]
Description=CoolShark Product Service (mall-product)
After=network.target mysqld.service redis.service
Wants=nacos.service

[Service]
Type=simple
User=ecs-user
EnvironmentFile=/data/jars/csmall.env
ExecStart=/usr/bin/java -jar /data/jars/mall-product-webapi-1.0.0.jar --spring.profiles.active=prod
ExecStop=/bin/kill -15 $MAINPID
KillMode=mixed
KillSignal=SIGTERM
TimeoutStopSec=30
Restart=on-failure
RestartSec=10

StandardOutput=append:/data/jars/logs/mall-product.log
StandardError=append:/data/jars/logs/mall-product.log

[Install]
WantedBy=multi-user.target