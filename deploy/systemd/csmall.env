# CoolShark 微服务 - 共享环境变量
# 部署到 /data/jars/csmall.env，所有 systemd 服务文件通过 EnvironmentFile 引用

# 服务器地址（单机部署使用 127.0.0.1）
ALIYUN_SERVER_IP=127.0.0.1

# MySQL 凭据
MYSQL_USERNAME=csmall_app
MYSQL_PASSWORD='Csmall2026!App'

# Redis 密码
REDIS_PASSWORD='Csmall2026!Redis'

# RabbitMQ 凭据
RABBITMQ_USERNAME=csmall_app
RABBITMQ_PASSWORD='Csmall2026!Rabbit'

# AI 智能导购（DeepSeek V4）
AI_API_KEY=sk-8f73ae480cfb4d97a749ebbe65dc5a4c
AI_API_BASE_URL=https://api.deepseek.com

# 文件资源 URL
RESOURCE_HOST=http://8.156.85.160/
