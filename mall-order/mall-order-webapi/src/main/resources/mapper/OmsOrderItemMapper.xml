<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.cooxiao.mall.order.mapper.OmsOrderItemMapper">

    <!-- 通用查询映射结果 -->
    <resultMap id="BaseResultMap" type="com.cooxiao.mall.pojo.order.model.OmsOrderItem">
        <id column="id" property="id" />
        <result column="order_id" property="orderId" />
        <result column="sku_id" property="skuId" />
        <result column="title" property="title" />
        <result column="bar_code" property="barCode" />
        <result column="sku_properties" property="data" />
        <result column="picture_url" property="mainPicture" />
        <result column="price" property="price" />
        <result column="quantity" property="quantity" />
        <result column="gmt_create" property="gmtCreate" />
        <result column="gmt_modified" property="gmtModified" />
    </resultMap>

    <!--   新增订单项(oms_order_item)的方法  -->
    <insert id="insertOrderItemList" >
        insert into oms_order_item(
        id,
        order_id,
        sku_id,
        title,
        bar_code,
        sku_properties,
        picture_url,
        price,
        quantity
        ) values
        <foreach collection="list" item="ooi" separator=",">
            (
            #{ooi.id},
            #{ooi.orderId},
            #{ooi.skuId},
            #{ooi.title},
            #{ooi.barCode},
            #{ooi.data},
            #{ooi.mainPicture},
            #{ooi.price},
            #{ooi.quantity}
            )
        </foreach>
    </insert>

    <!-- 根据订单id查询订单项列表 -->
    <select id="selectOrderItemsByOrderId" resultMap="BaseResultMap">
        SELECT * FROM oms_order_item WHERE order_id=#{orderId}
    </select>

</mapper>
